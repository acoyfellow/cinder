# Required for provisioning (alchemy.run.ts)
ALCHEMY_PASSWORD=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
GITHUB_WEBHOOK_SECRET=
CINDER_INTERNAL_TOKEN=
GITHUB_PAT=

# Optional: override .gateproof/runtime.json after provision
CINDER_BASE_URL=
CINDER_WORKER_NAME=

# Fixture repo for the proof (provision creates/updates this)
# Default: acoyfellow/cinder-prd-test
CINDER_FIXTURE_REPO=
CINDER_FIXTURE_BRANCH=
CINDER_FIXTURE_WORKFLOW=

# Speed claim: cold baseline (ms). If unset, gate 7 may measure via harness
COLD_BUILD_MS=
# Speed threshold: warm must be faster than cold - this many ms (default 60000)
SPEED_THRESHOLD_MS=
# Optional: real repo for gate 7 cold baseline measurement
TEST_REPO=
